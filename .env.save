EB_APP_ID=66452f5b-6cce-46a4-8d4b-c2c524fce4ab
EB_KEY_PATH=./private_key.pem
EB_SANDBOX=true# 
─────────────────────────────────────────────
#  Cuentas Backend · Configuración
#  Copia este archivo como .env y rellena los valores
# ─────────────────────────────────────────────

# ── Enablebanking ──────────────────────────────
# 1. Regístrate en https://enablebanking.com/sign-in/
# 2. Crea una aplicación en el Control Panel
# 3. Genera un par de claves RSA y sube la pública a Enablebanking
# 4. Copia aquí tu Application ID y la ruta a tu clave privada

EB_APP_ID=tu-application-id-aqui
EB_KEY_PATH=./private_key.pem
EB_SANDBOX=true

# ── Servidor ───────────────────────────────────
PORT=8000
APP_NAME=Cuentas

# ── URLs ───────────────────────────────────────
# URL donde Enablebanking redirige tras autenticación
REDIRECT_URL=http://localhost:8000/callback

# URL de la app frontend (para el botón "Volver a Cuentas")
# Deja vacío si la app está en el mismo servidor
FRONTEND_URL=
